<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gestionevenements.EventsSignedInController"
            styleClass="signed-in-clean-shell immersive-root signed-in-shell-root">
    <left>
        <StackPane fx:id="signedInSidebarHost" maxHeight="Infinity" minHeight="0.0" maxWidth="328.0" minWidth="260.0" prefWidth="292.0"
                   styleClass="signed-in-home-sidebar-host signed-in-shell-sidebar-host"
                   style="-fx-background-color: linear-gradient(to bottom, #07112E 0%, #081430 48%, #0A1635 100%); -fx-padding: 0;"
                   BorderPane.alignment="TOP_LEFT">
            <children>
                <Region fx:id="signedInSidebarEdgeAura" maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true"
                        styleClass="smart-auth-edge-aura" StackPane.alignment="CENTER"/>
                <VBox fx:id="signedInSidebarShell" spacing="10.0" styleClass="sv-si-sidebar signed-in-sidebar-column sidebar-immersive smart-auth-sidebar smart-auth-sidebar-outer" minHeight="0.0" maxHeight="Infinity" maxWidth="Infinity"
                       style="-fx-background-color: transparent;">
                    <children>
                        <VBox spacing="10.0" styleClass="smart-auth-brand-dock" VBox.vgrow="NEVER">
                            <padding>
                                <Insets top="22.0" right="26.0" bottom="6.0" left="26.0"/>
                            </padding>
                            <children>
                                <VBox spacing="8.0" styleClass="smart-auth-brand-lockup">
                                    <children>
                                        <ImageView fitWidth="212.0" pickOnBounds="true" preserveRatio="true" styleClass="smart-auth-brand-logo">
                                            <image>
                                                <Image url="@/assets/branding/smartvoyage-logo-tight.png"/>
                                            </image>
                                        </ImageView>
                                        <Region fx:id="signedInBrandUnderlineBar" prefHeight="3.0" maxWidth="132.0" styleClass="smart-auth-accent-bar"/>
                                        <Label text="Desktop travel UI" styleClass="smart-auth-brand-strap"/>
                                    </children>
                                </VBox>
                                <Label fx:id="signedInSidebarSessionLabel" text="" styleClass="sv-si-session"/>
                            </children>
                        </VBox>
                        <Region prefHeight="1.0" maxWidth="Infinity" styleClass="smart-auth-rule smart-auth-rule-tight"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navHomeButton" text="Home" onAction="#onHome" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navOffersButton" text="Offers" onAction="#onOffres" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navAgenciesButton" text="Agencies" onAction="#onAgences" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navMessagesButton" text="Messages" onAction="#onMessagerie" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navRecommendationsButton" text="Recommendations" onAction="#onRecommandation" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navEventsButton" text="Events" onAction="#onEvenement" styleClass="sidebar-nav-item"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navPremiumButton" text="Premium" onAction="#onPremium" styleClass="premium-nav-button" visible="false" managed="false"/>
                        <Button fx:id="navNotificationsButton" text="Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navProfileButton" text="My Profile" onAction="#onProfile" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navDashboardButton" text="Dashboard IA" onAction="#onDashboardIa" styleClass="sidebar-nav-item"/>
                        <Separator styleClass="sidebar-rule"/>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sv-si-footer">
                            <children>
                                <Button fx:id="signedInLogoutIconButton" text="" onAction="#onLogout"
                                        styleClass="signed-in-footer-logout-button" accessibleText="Logout"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </left>

    <center>
        <StackPane styleClass="signed-in-home-main-canvas signed-in-cosmic-canvas" maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-background-color: linear-gradient(to bottom, #2A174A 0%, #17052D 52%, #05010D 100%);">
            <children>
                <Pane fx:id="signedInCosmicStarfieldPane" styleClass="starfield-layer" maxWidth="Infinity" maxHeight="Infinity"/>

                <StackPane styleClass="offers-immersive-stack" maxWidth="Infinity" maxHeight="Infinity">
                    <children>
                        <Region styleClass="offers-page-overlay"/>
                        <Region styleClass="offers-cards-spotlight"/>

                        <VBox spacing="14.0" styleClass="events-root" maxWidth="Infinity" maxHeight="Infinity">
                            <padding><Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/></padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" styleClass="events-header">
                                    <children>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label fx:id="userGreetingLabel" text="Bienvenue" styleClass="events-title"/>
                                                <Label fx:id="roleLabel" text="User" styleClass="events-subtitle"/>
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <HBox spacing="8.0" alignment="CENTER_RIGHT">
                                            <children>
                                                <Button fx:id="allEventsButton" text="All events" onAction="#onAllEvents" styleClass="events-search-btn events-toolbar-btn"/>
                                                <Button fx:id="favoritesButton" text="Favoris" onAction="#onFavorites" styleClass="events-search-btn events-toolbar-btn"/>
                                                <Button fx:id="mesEventsButton" text="Mes events" onAction="#onMesEvents" styleClass="events-search-btn events-toolbar-btn"/>
                                                <Button fx:id="myRequestsButton" text="Mes demandes" onAction="#onMyRequests" styleClass="events-search-btn events-toolbar-btn"/>
                                                <Button fx:id="mySponsorsButton" text="Sponsors" onAction="#onMySponsors" styleClass="events-search-btn events-toolbar-btn"/>
                                                <Button fx:id="createEventButton" text="Create Event" onAction="#onCreateEvent" styleClass="events-create-btn"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                                <Label fx:id="eventsStatusLabel" managed="false" visible="false" wrapText="true" styleClass="events-inline-status"/>

                                <StackPane fx:id="eventsContentStack" VBox.vgrow="ALWAYS">
                                    <children>
                                        <VBox fx:id="eventsListView" spacing="12.0">
                                            <children>
                                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <TextField fx:id="eventSearchField" promptText="Search events by title, location, description..." onAction="#onSearchEvents"
                                                                   HBox.hgrow="ALWAYS" styleClass="events-search-input"/>
                                                        <Button text="Search" onAction="#onSearchEvents" styleClass="events-search-btn"/>
                                                    </children>
                                                </HBox>

                                                <HBox spacing="12.0" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
                                                    <children>
                                                        <ScrollPane fx:id="eventsScroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="events-scroll" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                                                            <content>
                                                                <TilePane fx:id="eventsTile" hgap="14.0" vgap="14.0" prefTileWidth="290.0" styleClass="events-tile"/>
                                                            </content>
                                                        </ScrollPane>

                                                        <VBox fx:id="ownerRequestsPanel" spacing="8.0" prefWidth="330.0" minWidth="300.0" maxWidth="360.0" managed="false" visible="false" styleClass="chart-container">
                                                            <children>
                                                                <Label fx:id="ownerRequestsTitleLabel" text="Pending Requests" styleClass="section-title"/>
                                                                <Label fx:id="ownerRequestsStatusLabel" managed="false" visible="false" wrapText="true" styleClass="events-inline-status"/>
                                                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="events-scroll" VBox.vgrow="ALWAYS">
                                                                    <content>
                                                                        <VBox fx:id="ownerRequestsList" spacing="8.0"/>
                                                                    </content>
                                                                </ScrollPane>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <VBox fx:id="eventsFormView" spacing="12.0" alignment="TOP_CENTER" managed="false" visible="false" styleClass="events-embedded-form-view">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" maxWidth="820.0">
                                                    <children>
                                                        <VBox spacing="2.0">
                                                            <children>
                                                                <Label fx:id="formTitleLabel" text="Create Event" styleClass="events-form-title"/>
                                                                <Label fx:id="formSubtitleLabel" text="Fill the details" styleClass="events-form-subtitle"/>
                                                            </children>
                                                        </VBox>
                                                        <Region HBox.hgrow="ALWAYS"/>
                                                        <Button text="Back" onAction="#onInlineCancel" styleClass="event-form-cancel-btn"/>
                                                    </children>
                                                </HBox>

                                                <Label fx:id="formStatusLabel" managed="false" visible="false" wrapText="true" styleClass="events-inline-status"/>

                                                <StackPane fx:id="embeddedFormHost" maxWidth="820.0" styleClass="events-embedded-form-host" VBox.vgrow="ALWAYS"/>

                                                <HBox alignment="CENTER_RIGHT" spacing="10.0" maxWidth="820.0" styleClass="events-form-actions-row">
                                                    <children>
                                                        <Button text="Cancel" onAction="#onInlineCancel" styleClass="event-form-cancel-btn"/>
                                                        <Button fx:id="formSubmitButton" text="Save" onAction="#onInlineSubmit" styleClass="event-form-ok-btn"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </StackPane>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
