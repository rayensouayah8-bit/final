<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gestionutilisateurs.UserProfileController"
            styleClass="signed-in-clean-shell immersive-root signed-in-shell-root">
    <left>
        <StackPane fx:id="signedInSidebarHost" maxHeight="Infinity" minHeight="0.0" maxWidth="328.0" minWidth="260.0" prefWidth="292.0"
                   styleClass="signed-in-home-sidebar-host signed-in-shell-sidebar-host"
                   style="-fx-background-color: linear-gradient(to bottom, #07112E 0%, #081430 48%, #0A1635 100%); -fx-padding: 0;"
                   BorderPane.alignment="TOP_LEFT">
            <children>
                <Region fx:id="signedInSidebarEdgeAura" maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true"
                        styleClass="smart-auth-edge-aura" StackPane.alignment="CENTER"/>
                <VBox fx:id="signedInSidebarShell" spacing="10.0" styleClass="sv-si-sidebar signed-in-sidebar-column sidebar-immersive smart-auth-sidebar smart-auth-sidebar-outer" minHeight="0.0" maxHeight="Infinity" maxWidth="Infinity"
                       style="-fx-background-color: transparent;">
                    <children>
                        <VBox spacing="10.0" styleClass="smart-auth-brand-dock" VBox.vgrow="NEVER">
                            <padding>
                                <Insets top="22.0" right="26.0" bottom="6.0" left="26.0"/>
                            </padding>
                            <children>
                                <VBox spacing="8.0" styleClass="smart-auth-brand-lockup">
                                    <children>
                                        <ImageView fitWidth="212.0" pickOnBounds="true" preserveRatio="true" styleClass="smart-auth-brand-logo">
                                            <image>
                                                <Image url="@/assets/branding/smartvoyage-logo-tight.png"/>
                                            </image>
                                        </ImageView>
                                        <Region fx:id="signedInBrandUnderlineBar" prefHeight="3.0" maxWidth="132.0" styleClass="smart-auth-accent-bar"/>
                                        <Label text="Desktop travel UI" styleClass="smart-auth-brand-strap"/>
                                    </children>
                                </VBox>
                                <Label fx:id="signedInSidebarSessionLabel" text="" styleClass="sv-si-session"/>
                            </children>
                        </VBox>
                        <Region prefHeight="1.0" maxWidth="Infinity" styleClass="smart-auth-rule smart-auth-rule-tight"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navHomeButton" text="Home" onAction="#onHome" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navOffersButton" text="Offers" onAction="#onOffres" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navAgenciesButton" text="Agencies" onAction="#onAgences" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navMessagesButton" text="Messages" onAction="#onMessagerie" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navRecommendationsButton" text="Recommendations" onAction="#onRecommandation" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navEventsButton" text="Events" onAction="#onEvenement" styleClass="sidebar-nav-item"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navPremiumButton" text="Premium" onAction="#onPremium" styleClass="premium-nav-button" visible="false" managed="false"/>
                        <Button fx:id="navNotificationsButton" text="Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navProfileButton" text="My Profile" onAction="#onProfile" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navDashboardButton" text="Dashboard IA" onAction="#onDashboardIa" styleClass="sidebar-nav-item"/>
                        <Separator styleClass="sidebar-rule"/>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sv-si-footer">
                            <children>
                                <Button fx:id="signedInLogoutIconButton" text="" onAction="#onLogout"
                                        styleClass="signed-in-footer-logout-button" accessibleText="Logout"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </left>

    <center>
        <StackPane styleClass="signed-in-home-main-canvas signed-in-cosmic-canvas" maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-background-color: linear-gradient(to bottom, #2A174A 0%, #17052D 52%, #05010D 100%);">
            <children>
                <Pane fx:id="signedInCosmicStarfieldPane" styleClass="starfield-layer" maxWidth="Infinity" maxHeight="Infinity"/>
                <ScrollPane fx:id="userProfilePageScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" minHeight="0.0" styleClass="agency-page-scroll">
                    <content>
                        <VBox spacing="22.0" styleClass="user-profile-root" maxWidth="1360.0">
                    <padding><Insets top="26.0" right="26.0" bottom="30.0" left="26.0"/></padding>
                    <children>
                        <VBox spacing="6.0" styleClass="user-profile-header">
                            <children>
                                <Label text="My Profile" styleClass="user-profile-kicker"/>
                                <Label fx:id="pageTitleLabel" text="My Profile" styleClass="user-profile-title"/>
                                <Label text="Mettez a jour vos informations personnelles." styleClass="user-profile-subtitle"/>
                            </children>
                        </VBox>

                        <HBox spacing="24.0" alignment="TOP_LEFT">
                            <children>
                                <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                                    <styleClass>
                                        <String fx:value="user-profile-card"/>
                                        <String fx:value="user-profile-main-card"/>
                                    </styleClass>
                                    <padding><Insets top="28.0" right="28.0" bottom="26.0" left="28.0"/></padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label text="Personal information" styleClass="user-profile-section-title"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Button text="Save" onAction="#onSaveProfile" styleClass="user-profile-save-btn"/>
                                            </children>
                                        </HBox>
                                        <HBox spacing="34.0" alignment="TOP_LEFT">
                                            <children>
                                                <VBox alignment="TOP_CENTER" spacing="0.0">
                                                    <children>
                                                        <StackPane styleClass="user-profile-avatar-shell">
                                                            <children>
                                                                <StackPane fx:id="profileAvatarClipStack" maxHeight="148.0" maxWidth="148.0" minHeight="148.0" minWidth="148.0"
                                                                           prefHeight="148.0" prefWidth="148.0" styleClass="user-profile-avatar-inner">
                                                                    <children>
                                                                        <Label fx:id="profileImageFallbackLabel" text="U" styleClass="user-profile-avatar-fallback"
                                                                               StackPane.alignment="CENTER"/>
                                                                        <ImageView fx:id="profileImageView" pickOnBounds="false" preserveRatio="true" smooth="true"/>
                                                                    </children>
                                                                </StackPane>
                                                                <Button fx:id="profilePhotoChangeButton" id="profilePhotoChangeButton"
                                                                        mnemonicParsing="false" onAction="#onProfilePhotoChange"
                                                                        pickOnBounds="false" text="+"
                                                                        styleClass="user-profile-avatar-fab user-profile-avatar-fab-change"
                                                                        StackPane.alignment="BOTTOM_RIGHT"/>
                                                                <Button fx:id="profilePhotoDeleteButton" id="profilePhotoDeleteButton"
                                                                        mnemonicParsing="false" onAction="#onProfilePhotoDelete"
                                                                        pickOnBounds="false" text="×"
                                                                        styleClass="user-profile-avatar-fab user-profile-avatar-fab-delete user-profile-avatar-fab-change"
                                                                        StackPane.alignment="BOTTOM_RIGHT"/>
                                                            </children>
                                                        </StackPane>
                                                    </children>
                                                </VBox>
                                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="Username" styleClass="user-profile-label"/>
                                                        <TextField fx:id="usernameField" promptText="Your username" styleClass="user-profile-input"/>
                                                        <Label fx:id="usernameErrorLabel" managed="false" visible="false" styleClass="user-profile-error"/>
                                                        <Label text="Email" styleClass="user-profile-label"/>
                                                        <TextField fx:id="emailField" promptText="votre@email.com" styleClass="user-profile-input"/>
                                                        <Label fx:id="emailErrorLabel" managed="false" visible="false" styleClass="user-profile-error"/>
                                                        <Label text="Phone" styleClass="user-profile-label"/>
                                                        <TextField fx:id="phoneField" promptText="+216 99 999 999" styleClass="user-profile-input"/>
                                                        <Label fx:id="phoneErrorLabel" managed="false" visible="false" styleClass="user-profile-error"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <Label fx:id="statusLabel" managed="false" visible="false" wrapText="true" styleClass="user-profile-status"/>
                                    </children>
                                </VBox>

                                <VBox spacing="18.0" prefWidth="400.0" minWidth="320.0" maxWidth="460.0">
                                    <children>
                                        <VBox spacing="10.0">
                                            <styleClass>
                                                <String fx:value="user-profile-card"/>
                                                <String fx:value="user-profile-side-card"/>
                                            </styleClass>
                                            <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/></padding>
                                            <children>
                                                <Label text="Created events" styleClass="user-profile-section-title"/>
                                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="user-profile-mini-scroll">
                                                    <content>
                                                        <VBox fx:id="eventsCreatedBox" spacing="8.0"/>
                                                    </content>
                                                </ScrollPane>
                                            </children>
                                        </VBox>

                                        <VBox spacing="10.0">
                                            <styleClass>
                                                <String fx:value="user-profile-card"/>
                                                <String fx:value="user-profile-side-card"/>
                                            </styleClass>
                                            <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/></padding>
                                            <children>
                                                <Label text="Rate the app" styleClass="user-profile-section-title"/>
                                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Button fx:id="feedbackStar1Button" text="★" userData="1"
                                                                onAction="#onFeedbackStarSelected"
                                                                onMouseEntered="#onFeedbackStarHover"
                                                                onMouseExited="#onFeedbackStarExit"
                                                                styleClass="star-rating-button"/>
                                                        <Button fx:id="feedbackStar2Button" text="★" userData="2"
                                                                onAction="#onFeedbackStarSelected"
                                                                onMouseEntered="#onFeedbackStarHover"
                                                                onMouseExited="#onFeedbackStarExit"
                                                                styleClass="star-rating-button"/>
                                                        <Button fx:id="feedbackStar3Button" text="★" userData="3"
                                                                onAction="#onFeedbackStarSelected"
                                                                onMouseEntered="#onFeedbackStarHover"
                                                                onMouseExited="#onFeedbackStarExit"
                                                                styleClass="star-rating-button"/>
                                                        <Button fx:id="feedbackStar4Button" text="★" userData="4"
                                                                onAction="#onFeedbackStarSelected"
                                                                onMouseEntered="#onFeedbackStarHover"
                                                                onMouseExited="#onFeedbackStarExit"
                                                                styleClass="star-rating-button"/>
                                                        <Button fx:id="feedbackStar5Button" text="★" userData="5"
                                                                onAction="#onFeedbackStarSelected"
                                                                onMouseEntered="#onFeedbackStarHover"
                                                                onMouseExited="#onFeedbackStarExit"
                                                                styleClass="star-rating-button"/>
                                                    </children>
                                                </HBox>
                                                <TextArea fx:id="feedbackNoteArea" promptText="Your feedback..." wrapText="true" prefRowCount="3" styleClass="user-profile-input"/>
                                                <Button text="Publish feedback" onAction="#onSubmitFeedback" styleClass="user-profile-image-btn"/>
                                                <Label fx:id="feedbackStatusLabel" managed="false" visible="false" wrapText="true" styleClass="user-profile-status"/>
                                                <Label text="My previous feedback" styleClass="user-profile-label"/>
                                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="user-profile-mini-scroll">
                                                    <content>
                                                        <VBox fx:id="feedbackHistoryBox" spacing="8.0"/>
                                                    </content>
                                                </ScrollPane>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
