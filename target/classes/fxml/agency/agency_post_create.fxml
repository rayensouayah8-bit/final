<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gestionagences.AgencyPostCreateController"
            styleClass="signed-in-clean-shell immersive-root signed-in-shell-root">
    <left>
        <StackPane fx:id="signedInSidebarHost" maxHeight="Infinity" minHeight="0.0" maxWidth="328.0" minWidth="260.0" prefWidth="292.0"
                   styleClass="signed-in-home-sidebar-host signed-in-shell-sidebar-host"
                   style="-fx-background-color: linear-gradient(to bottom, #07112E 0%, #081430 48%, #0A1635 100%); -fx-padding: 0;"
                   BorderPane.alignment="TOP_LEFT">
            <children>
                <Region fx:id="signedInSidebarEdgeAura" maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true"
                        styleClass="smart-auth-edge-aura" StackPane.alignment="CENTER"/>
                <VBox fx:id="signedInSidebarShell" spacing="10.0" styleClass="sv-si-sidebar signed-in-sidebar-column sidebar-immersive smart-auth-sidebar smart-auth-sidebar-outer" minHeight="0.0" maxHeight="Infinity" maxWidth="Infinity"
                       style="-fx-background-color: transparent;">
                    <children>
                        <VBox spacing="10.0" styleClass="smart-auth-brand-dock" VBox.vgrow="NEVER">
                            <padding>
                                <Insets top="22.0" right="26.0" bottom="6.0" left="26.0"/>
                            </padding>
                            <children>
                                <VBox spacing="8.0" styleClass="smart-auth-brand-lockup">
                                    <children>
                                        <ImageView fitWidth="212.0" pickOnBounds="true" preserveRatio="true" styleClass="smart-auth-brand-logo">
                                            <image>
                                                <Image url="@/assets/branding/smartvoyage-logo-tight.png"/>
                                            </image>
                                        </ImageView>
                                        <Region fx:id="signedInBrandUnderlineBar" prefHeight="3.0" maxWidth="132.0" styleClass="smart-auth-accent-bar"/>
                                        <Label text="Desktop travel UI" styleClass="smart-auth-brand-strap"/>
                                    </children>
                                </VBox>
                                <Label fx:id="signedInSidebarSessionLabel" text="" styleClass="sv-si-session"/>
                            </children>
                        </VBox>
                        <Region prefHeight="1.0" maxWidth="Infinity" styleClass="smart-auth-rule smart-auth-rule-tight"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navHomeButton" text="Home" onAction="#onHome" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navOffersButton" text="Offers" onAction="#onOffres" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navAgenciesButton" text="Agencies" onAction="#onAgences" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navMessagesButton" text="Messages" onAction="#onMessagerie" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navRecommendationsButton" text="Recommendations" onAction="#onRecommandation" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navEventsButton" text="Events" onAction="#onEvenement" styleClass="sidebar-nav-item"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navPremiumButton" text="Premium" onAction="#onPremium" styleClass="premium-nav-button" visible="false" managed="false"/>
                        <Button fx:id="navNotificationsButton" text="Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navProfileButton" text="My Profile" onAction="#onProfile" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navDashboardButton" text="Dashboard IA" onAction="#onDashboardIa" styleClass="sidebar-nav-item"/>
                        <Separator styleClass="sidebar-rule"/>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sv-si-footer">
                            <children>
                                <Button fx:id="signedInLogoutIconButton" text="" onAction="#onLogout"
                                        styleClass="signed-in-footer-logout-button" accessibleText="Logout"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </left>

    <center>
        <StackPane styleClass="signed-in-home-main-canvas signed-in-cosmic-canvas" maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-background-color: linear-gradient(to bottom, #2A174A 0%, #17052D 52%, #05010D 100%);">
            <children>
                <Pane fx:id="signedInCosmicStarfieldPane" styleClass="starfield-layer" maxWidth="Infinity" maxHeight="Infinity"/>
                <VBox spacing="16.0" styleClass="agency-page-root">
                    <padding><Insets top="20.0" right="24.0" bottom="20.0" left="24.0"/></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="agency-header-row">
                            <children>
                                <Label text="Create Agency Post" styleClass="offers-mini-logo"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Back to agency" onAction="#onCancel" styleClass="offers-top-login-button"/>
                            </children>
                        </HBox>

                        <VBox spacing="14.0" styleClass="agency-main-content-panel agency-post-create-panel" VBox.vgrow="ALWAYS">
                            <padding><Insets top="20.0" right="22.0" bottom="20.0" left="22.0"/></padding>
                            <children>
                                <VBox spacing="4.0" styleClass="agency-post-create-field">
                                    <children>
                                        <Label text="Post title" styleClass="agency-post-create-label"/>
                                        <TextField fx:id="titleField" promptText="Write a clear title" styleClass="agency-post-create-input"/>
                                        <Label fx:id="titleErrorLabel" styleClass="agency-post-create-field-error" wrapText="true" maxWidth="1.7976931348623157E308" managed="false" visible="false"/>
                                    </children>
                                </VBox>

                                <VBox spacing="4.0" styleClass="agency-post-create-field">
                                    <children>
                                        <Label text="Post content" styleClass="agency-post-create-label"/>
                                        <TextArea fx:id="contentArea" promptText="Share your agency update..." prefRowCount="8" wrapText="true" styleClass="agency-post-create-textarea"/>
                                        <Label fx:id="contentErrorLabel" styleClass="agency-post-create-field-error" wrapText="true" maxWidth="1.7976931348623157E308" managed="false" visible="false"/>
                                    </children>
                                </VBox>

                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="Choose images (one or multiple)" onAction="#onChooseImages" styleClass="agency-overlay-action agency-post-create-upload-btn"/>
                                    </children>
                                </HBox>
                                <VBox fx:id="dropArea" spacing="8.0" styleClass="agency-upload-drop-area">
                                    <padding><Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/></padding>
                                    <children>
                                        <Label fx:id="dropHintLabel" text="Drag and drop images here, or use the button above." styleClass="agency-post-create-drop-hint"/>
                                    </children>
                                </VBox>
                                <ScrollPane fitToWidth="true" minHeight="220.0" prefHeight="320.0" maxHeight="420.0" styleClass="agency-card-scroll agency-upload-thumbs-scroll">
                                    <content>
                                        <FlowPane fx:id="thumbnailsFlow" hgap="14.0" vgap="14.0" prefWrapLength="880.0"/>
                                    </content>
                                </ScrollPane>
                                <ListView fx:id="uploadErrorsList" prefHeight="92.0" visible="false" managed="false" styleClass="agency-upload-errors-list"/>

                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="Create post" onAction="#onCreatePost" styleClass="agency-overlay-action agency-post-create-submit-btn"/>
                                        <Button text="Cancel" onAction="#onCancel" styleClass="agency-overlay-action agency-post-create-cancel-btn"/>
                                    </children>
                                </HBox>

                                <Label fx:id="feedbackLabel" text="" styleClass="agency-post-create-feedback" wrapText="true" maxWidth="1.7976931348623157E308"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
