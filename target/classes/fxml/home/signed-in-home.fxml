<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.home.SignedInHomeController"
            styleClass="signed-in-clean-shell signed-in-home-root immersive-root signed-in-shell-root"
            maxWidth="Infinity" maxHeight="Infinity">
    <left>
        <StackPane fx:id="signedInSidebarHost" maxHeight="Infinity" minHeight="0.0" maxWidth="328.0" minWidth="260.0" prefWidth="292.0"
                   styleClass="signed-in-home-sidebar-host signed-in-shell-sidebar-host"
                   style="-fx-background-color: linear-gradient(to bottom, #07112E 0%, #081430 48%, #0A1635 100%); -fx-padding: 0;"
                   BorderPane.alignment="TOP_LEFT">
            <children>
                <Region fx:id="signedInSidebarEdgeAura" maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true"
                        styleClass="smart-auth-edge-aura" StackPane.alignment="CENTER"/>
                <VBox fx:id="signedInSidebarShell" spacing="10.0" styleClass="sv-si-sidebar signed-in-sidebar-column sidebar-immersive smart-auth-sidebar smart-auth-sidebar-outer" minHeight="0.0" maxHeight="Infinity" maxWidth="Infinity"
                       style="-fx-background-color: transparent;">
                    <children>
                        <VBox spacing="10.0" styleClass="smart-auth-brand-dock" VBox.vgrow="NEVER">
                            <padding>
                                <Insets top="22.0" right="26.0" bottom="6.0" left="26.0"/>
                            </padding>
                            <children>
                                <VBox spacing="8.0" styleClass="smart-auth-brand-lockup">
                                    <children>
                                        <ImageView fitWidth="212.0" pickOnBounds="true" preserveRatio="true" styleClass="smart-auth-brand-logo">
                                            <image>
                                                <Image url="@/assets/branding/smartvoyage-logo-tight.png"/>
                                            </image>
                                        </ImageView>
                                        <Region fx:id="signedInBrandUnderlineBar" prefHeight="3.0" maxWidth="132.0" styleClass="smart-auth-accent-bar"/>
                                        <Label text="Desktop travel UI" styleClass="smart-auth-brand-strap"/>
                                    </children>
                                </VBox>
                                <Label fx:id="signedInSidebarSessionLabel" text="" styleClass="sv-si-session"/>
                            </children>
                        </VBox>
                        <Region prefHeight="1.0" maxWidth="Infinity" styleClass="smart-auth-rule smart-auth-rule-tight"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navHomeButton" text="Home" onAction="#onHome" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navOffersButton" text="Offers" onAction="#onOffres" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navAgenciesButton" text="Agencies" onAction="#onAgences" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navMessagesButton" text="Messages" onAction="#onMessagerie" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navRecommendationsButton" text="Recommendations" onAction="#onRecommandation" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navEventsButton" text="Events" onAction="#onEvenement" styleClass="sidebar-nav-item"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navPremiumButton" text="Premium" onAction="#onPremium" styleClass="premium-nav-button" visible="false" managed="false"/>
                        <Button fx:id="navNotificationsButton" text="Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navProfileButton" text="My Profile" onAction="#onProfile" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navDashboardButton" text="Dashboard IA" onAction="#onDashboardIa" styleClass="sidebar-nav-item"/>
                        <Separator styleClass="sidebar-rule"/>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sv-si-footer">
                            <children>
                                <Button fx:id="signedInLogoutIconButton" text="" onAction="#onLogout"
                                        styleClass="signed-in-footer-logout-button" accessibleText="Logout"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </left>
    <center>
        <StackPane styleClass="signed-in-home-main-canvas signed-in-cosmic-canvas" maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-background-color: linear-gradient(to bottom, #2A174A 0%, #17052D 52%, #05010D 100%);">
            <children>
                <Pane fx:id="signedInStarfieldPane" styleClass="starfield-layer" maxWidth="Infinity" maxHeight="Infinity"/>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" minHeight="0.0" styleClass="agency-page-scroll">
                    <content>
                        <BorderPane styleClass="signed-in-home-main-stage" pickOnBounds="false" maxWidth="Infinity" maxHeight="Infinity">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="20.0" left="16.0"/>
                            </padding>
                            <center>
                                <VBox alignment="TOP_LEFT" spacing="14.0" styleClass="signed-in-home-main-body" maxWidth="Infinity" maxHeight="Infinity" VBox.vgrow="ALWAYS">
                                    <padding>
                                        <Insets top="8.0" right="40.0" bottom="20.0" left="40.0"/>
                                    </padding>
                                    <children>
                                        <Label text="TRAVEL ON YOUR TERMS" styleClass="micro-label home-hero-kicker home-welcome-kicker"
                                               style="-fx-text-fill: #c4b5fd; -fx-font-size: 12px; -fx-font-weight: 700; -fx-letter-spacing: 3.2px; -fx-padding: 10 18 10 18; -fx-background-color: rgba(196, 181, 253, 0.12); -fx-background-radius: 999; -fx-border-color: rgba(196, 181, 253, 0.30); -fx-border-radius: 999;"/>
                                        <Label text="Discover the&#10;world&#10;your way." styleClass="hero-title hero-title-glow home-welcome-title"
                                               style="-fx-text-fill: #ffffff; -fx-font-family: 'Bebas Neue', 'Arial'; -fx-font-size: 102px; -fx-line-spacing: 4px; -fx-effect: dropshadow(gaussian, rgba(139, 92, 246, 0.35), 32, 0.24, 0, 4);"
                                               wrapText="true" maxWidth="860.0"/>
                                        <Label text="From hidden gems to iconic destinations, SmartVoyage helps you plan unforgettable journeys with a premium desktop experience."
                                               wrapText="true" maxWidth="1020.0" styleClass="hero-subtitle home-hero-subtitle home-welcome-subtitle"
                                               style="-fx-text-fill: rgba(226, 232, 240, 0.94); -fx-font-size: 18px; -fx-line-spacing: 6px;"/>
                                        <Label fx:id="userGreetingLabel" text="" styleClass="home-hero-meta home-welcome-meta" wrapText="true" maxWidth="980.0"
                                               style="-fx-text-fill: rgba(226, 232, 240, 0.92); -fx-font-size: 17px; -fx-font-weight: 500;"/>
                                        <Label fx:id="roleLabel" text="" styleClass="home-hero-meta home-welcome-meta" wrapText="true" maxWidth="980.0"
                                               style="-fx-text-fill: rgba(226, 232, 240, 0.92); -fx-font-size: 17px; -fx-font-weight: 500;"/>
                                    </children>
                                </VBox>
                            </center>
                        </BorderPane>
                    </content>
                </ScrollPane>
                <StackPane fx:id="signedInEntryOverlay" visible="false" managed="false" mouseTransparent="true"
                           styleClass="signed-in-entry-overlay">
                    <children>
                        <VBox fx:id="signedInEntryBrandCard" alignment="CENTER_LEFT" spacing="10.0"
                              styleClass="signed-in-entry-brand-card">
                            <children>
                                <ImageView fitWidth="250.0" pickOnBounds="true" preserveRatio="true" styleClass="smart-auth-brand-logo">
                                    <image>
                                        <Image url="@/assets/branding/smartvoyage-logo-tight.png"/>
                                    </image>
                                </ImageView>
                                <Region fx:id="signedInEntryUnderlineBar" prefHeight="3.0" maxWidth="140.0"
                                        styleClass="smart-auth-accent-bar"/>
                                <Label text="Desktop travel UI" styleClass="smart-auth-brand-strap"/>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
