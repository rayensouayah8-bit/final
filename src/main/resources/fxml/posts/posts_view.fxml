<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gestionposts.PostsController"
            styleClass="signed-in-clean-shell immersive-root signed-in-shell-root">

    <left>
        <StackPane fx:id="signedInSidebarHost" maxHeight="Infinity" minHeight="0.0" maxWidth="328.0" minWidth="260.0" prefWidth="292.0"
                   styleClass="signed-in-home-sidebar-host signed-in-shell-sidebar-host"
                   style="-fx-background-color: linear-gradient(to bottom, #07112E 0%, #081430 48%, #0A1635 100%); -fx-padding: 0;"
                   BorderPane.alignment="TOP_LEFT">
            <children>
                <Region fx:id="signedInSidebarEdgeAura" maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true"
                        styleClass="smart-auth-edge-aura" StackPane.alignment="CENTER"/>
                <VBox fx:id="signedInSidebarShell" spacing="10.0" styleClass="sv-si-sidebar signed-in-sidebar-column sidebar-immersive smart-auth-sidebar smart-auth-sidebar-outer" minHeight="0.0" maxHeight="Infinity" maxWidth="Infinity"
                       style="-fx-background-color: transparent;">
                    <children>
                        <VBox spacing="10.0" styleClass="smart-auth-brand-dock" VBox.vgrow="NEVER">
                            <padding>
                                <Insets top="22.0" right="26.0" bottom="6.0" left="26.0"/>
                            </padding>
                            <children>
                                <VBox spacing="8.0" styleClass="smart-auth-brand-lockup">
                                    <children>
                                        <ImageView fitWidth="212.0" pickOnBounds="true" preserveRatio="true" styleClass="smart-auth-brand-logo">
                                            <image>
                                                <Image url="@/assets/branding/smartvoyage-logo-tight.png"/>
                                            </image>
                                        </ImageView>
                                        <Region fx:id="signedInBrandUnderlineBar" prefHeight="3.0" maxWidth="132.0" styleClass="smart-auth-accent-bar"/>
                                        <Label text="Desktop travel UI" styleClass="smart-auth-brand-strap"/>
                                    </children>
                                </VBox>
                                <Label fx:id="signedInSidebarSessionLabel" text="" styleClass="sv-si-session"/>
                            </children>
                        </VBox>
                        <Region prefHeight="1.0" maxWidth="Infinity" styleClass="smart-auth-rule smart-auth-rule-tight"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navHomeButton" text="Home" onAction="#onHome" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navOffersButton" text="Offers" onAction="#onOffres" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navAgenciesButton" text="Agencies" onAction="#onAgences" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navMessagesButton" text="Messages" onAction="#onMessagerie" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navRecommendationsButton" text="Recommendations" onAction="#onRecommandation" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navEventsButton" text="Events" onAction="#onEvenement" styleClass="sidebar-nav-item"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navPremiumButton" text="Premium" onAction="#onPremium" styleClass="premium-nav-button" visible="false" managed="false"/>
                        <Button fx:id="navNotificationsButton" text="Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navProfileButton" text="My Profile" onAction="#onProfile" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navDashboardButton" text="Dashboard IA" onAction="#onDashboardIa" styleClass="sidebar-nav-item"/>
                        <Separator styleClass="sidebar-rule"/>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sv-si-footer">
                            <children>
                                <Button fx:id="signedInLogoutIconButton" text="" onAction="#onLogout"
                                        styleClass="signed-in-footer-logout-button" accessibleText="Logout"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </left>

    <center>
        <StackPane styleClass="signed-in-home-main-canvas signed-in-cosmic-canvas" maxWidth="Infinity" maxHeight="Infinity"
                   style="-fx-background-color: linear-gradient(to bottom, #2A174A 0%, #17052D 52%, #05010D 100%);">
            <children>
                <Pane fx:id="signedInCosmicStarfieldPane" styleClass="starfield-layer" maxWidth="Infinity" maxHeight="Infinity"/>

                <BorderPane pickOnBounds="false" styleClass="hero-foreground-pane">
                    <padding>
                        <Insets top="10.0" right="34.0" bottom="28.0" left="34.0"/>
                    </padding>
                    <top>
                        <VBox spacing="12.0">
                            <children>
                                <Label fx:id="postsStatusLabel" managed="false" visible="false" wrapText="true" styleClass="posts-inline-status"/>

                                <VBox spacing="6.0" styleClass="user-profile-header">
                                    <children>
                                        <Label fx:id="userGreetingLabel" text="Bienvenue" styleClass="user-profile-kicker"/>
                                        <Label text="Recommendations" styleClass="user-profile-title"/>
                                        <Label fx:id="roleLabel" text="Utilisateur" styleClass="user-profile-subtitle"/>
                                    </children>
                                </VBox>

                                <VBox fx:id="postsDirectoryFiltersRoot" spacing="10.0"
                                      styleClass="user-profile-card agency-directory-filters-card agency-directory-filters-root">
                                    <padding>
                                        <Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/>
                                    </padding>
                                    <children>
                                        <HBox spacing="10.0" alignment="CENTER" styleClass="posts-view-mode-toggle-row">
                                            <children>
                                                <Button fx:id="mapButton" text="Voir sur la carte" onAction="#onOpenPostsMap" mnemonicParsing="false"
                                                        styleClass="button agency-map-purple-button"/>
                                                <Button fx:id="refreshTrendingButton" text="🔥 Actualiser tendances" onAction="#onRefreshTrending"
                                                        mnemonicParsing="false" styleClass="button agency-map-purple-button"/>
                                                <Button fx:id="addPostButton" text="+ New post" onAction="#onAddPost" mnemonicParsing="false"
                                                        styleClass="button agency-map-purple-button"/>
                                            </children>
                                        </HBox>
                                        <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="posts-view-mode-toggle-row">
                                            <children>
                                                <Button fx:id="myPostsButton" text="Mes posts" onAction="#onMyPosts" mnemonicParsing="false"
                                                        styleClass="button agency-my-agency-outline"/>
                                                <Button fx:id="browseAllPostsButton" text="Tous les posts" onAction="#onBrowseAllPosts" mnemonicParsing="false"
                                                        styleClass="button agency-map-purple-button"/>
                                            </children>
                                        </HBox>
                                        <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="agency-symfony-filter-bar">
                                            <children>
                                                <TextField fx:id="searchField" promptText="Search by title, content or location..." minWidth="220.0" HBox.hgrow="ALWAYS"
                                                           styleClass="text-input text-field agency-symfony-search"/>
                                                <Button fx:id="voiceSearchButton" text="🎙️" onAction="#onVoiceSearch" mnemonicParsing="false"
                                                        styleClass="button agency-map-purple-button"/>
                                                <ComboBox fx:id="countryComboBox" promptText="Filter by country" prefWidth="220.0" minWidth="160.0" maxWidth="300.0"
                                                          styleClass="combo-box agency-symfony-choice"/>
                                                <Button fx:id="searchButton" text="Search" onAction="#onSearch" mnemonicParsing="false"
                                                        styleClass="button agency-map-purple-button"/>
                                                <Button fx:id="clearFiltersButton" text="Clear" onAction="#onClearFilters" mnemonicParsing="false"
                                                        styleClass="button agency-my-agency-outline"/>
                                            </children>
                                        </HBox>
                                        <HBox spacing="14.0" alignment="CENTER_LEFT" styleClass="agency-symfony-filter-bar">
                                            <children>
                                                <TextField fx:id="chatbotPromptField" promptText="🤖 Chatbot recommandations : ex. Maroc / affiche posts sur France" minWidth="260.0" HBox.hgrow="ALWAYS"
                                                           styleClass="text-input text-field agency-symfony-search"/>
                                                <Button fx:id="chatbotGenerateButton" text="✨ Générer post" onAction="#onChatbotGeneratePost" mnemonicParsing="false" minWidth="150.0" prefWidth="170.0"
                                                        styleClass="button agency-map-purple-button"/>
                                                <Button fx:id="chatbotNavigateButton" text="🧭 Naviguer" onAction="#onChatbotNavigate" mnemonicParsing="false" minWidth="130.0" prefWidth="150.0"
                                                        styleClass="button agency-my-agency-outline"/>
                                            </children>
                                        </HBox>
                                        <Label fx:id="postsResultCountLabel" text="" styleClass="agency-result-count-label"/>
                                        <Label fx:id="chatbotStatusLabel" managed="false" visible="false" wrapText="true" styleClass="posts-inline-status"/>
                                        <Label fx:id="voiceSearchStatusLabel" managed="false" visible="false" wrapText="true" styleClass="posts-inline-status"/>
                                        <Label fx:id="trendingBannerLabel" managed="false" visible="false" wrapText="true" styleClass="posts-inline-status"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </top>
                    <center>
                        <StackPane fx:id="contentStack" maxWidth="Infinity" maxHeight="Infinity">
                            <children>
                                <VBox fx:id="listView" spacing="10.0" styleClass="posts-list-view">
                                    <children>
                                        <ScrollPane fx:id="postsScrollPane" fitToWidth="true" minHeight="0.0" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" pannable="true"
                                                    styleClass="scroll-pane agency-directory-scroll"
                                                    style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                                            <content>
                                                <FlowPane fx:id="postsFlowPane" styleClass="posts-flow agency-directory-grid"
                                                          style="-fx-background-color: transparent;">
                                                    <padding>
                                                        <Insets top="10.0" right="8.0" bottom="28.0" left="8.0"/>
                                                    </padding>
                                                </FlowPane>
                                            </content>
                                        </ScrollPane>

                                        <HBox spacing="12.0" alignment="CENTER" styleClass="posts-pagination">
                                            <children>
                                                <Button fx:id="prevPageButton" text="◀ Previous" onAction="#onPrevPage" styleClass="posts-page-btn"/>
                                                <Label fx:id="pageLabel" text="Page 1 / 1" styleClass="posts-page-label"/>
                                                <Button fx:id="nextPageButton" text="Next ▶" onAction="#onNextPage" styleClass="posts-page-btn"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="totalPostsLabel" text="Total: 0 posts" styleClass="posts-total-label"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="formView" spacing="12.0" styleClass="posts-form-view" managed="false" visible="false"
                                      minHeight="0.0" maxHeight="Infinity" VBox.vgrow="ALWAYS">
                                    <children>
                                        <!-- Form Header -->
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label fx:id="formTitleLabel" text="Nouveau Post" styleClass="posts-form-title"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Button text="← Retour" onAction="#onBackToList" styleClass="posts-back-btn"/>
                                            </children>
                                        </HBox>

                                        <!-- Error Label -->
                                        <Label fx:id="formErrorLabel" managed="false" visible="false" wrapText="true" styleClass="posts-inline-status"/>

                                        <StackPane minHeight="0.0" VBox.vgrow="ALWAYS">
                                            <children>
                                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" pannable="false"
                                                    styleClass="scroll-pane agency-directory-scroll"
                                                    style="-fx-background-color: transparent; -fx-background: transparent;"
                                                    minHeight="0.0" maxHeight="Infinity">
                                            <content>
                                        <!-- Form Fields -->
                                        <VBox spacing="16.0" styleClass="posts-form-content" minHeight="0.0">
                                            <padding>
                                                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
                                            </padding>
                                            <children>
                                                <!-- Titre -->
                                                <VBox spacing="4.0">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <Label text="Titre *" styleClass="posts-form-label"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Label fx:id="titreCounter" text="0/100" styleClass="posts-form-counter"/>
                                                            </children>
                                                        </HBox>
                                                        <TextField fx:id="formTitreField" promptText="Entrez le titre (10-100 caractères)" styleClass="posts-form-input"/>
                                                    </children>
                                                </VBox>

                                                <!-- Location -->
                                                <VBox spacing="4.0">
                                                    <children>
                                                        <Label text="Pays / Localisation *" styleClass="posts-form-label"/>
                                                        <ComboBox fx:id="formLocationCombo" promptText="Sélectionnez un pays" editable="true" styleClass="posts-form-combo"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="6.0">
                                                    <children>
                                                        <Label text="Géolocalisation" styleClass="posts-form-label"/>
                                                        <CheckBox fx:id="attachGeoCheckBox" text="Associer des coordonnées au post (affichage sur la carte)" mnemonicParsing="false"/>
                                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                            <children>
                                                                <Button fx:id="detectLocationButton" text="Détecter ma position (IP)" onAction="#onDetectFormLocation" mnemonicParsing="false"
                                                                        styleClass="posts-form-browse-btn"/>
                                                                <Label fx:id="formGeoStatusLabel" text="" styleClass="posts-form-counter" wrapText="true"/>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>

                                                <!-- Media -->
                                                <VBox spacing="8.0">
                                                    <children>
                                                        <Label text="Media" styleClass="posts-form-label"/>
                                                        <Label text="Glissez-déposez une image sur le formulaire ou utilisez les boutons IA ci-dessous." styleClass="posts-form-counter" wrapText="true"/>
                                                        <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                            <children>
                                                                <StackPane styleClass="post-inline-preview-shell">
                                                                    <children>
                                                                        <ImageView fx:id="formImagePreview" fitWidth="60" fitHeight="60" preserveRatio="false" smooth="true"/>
                                                                    </children>
                                                                </StackPane>
                                                                <TextField fx:id="formImageUrlField" promptText="Local path or URL" HBox.hgrow="ALWAYS" styleClass="posts-form-input"/>
                                                                <Button text="Browse" onAction="#onBrowseFormImage" styleClass="posts-form-browse-btn"/>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>

                                                <!-- Contenu -->
                                                <VBox spacing="4.0">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT">
                                                            <children>
                                                                <Label text="Contenu *" styleClass="posts-form-label"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Label fx:id="contenuCounter" text="0/5000" styleClass="posts-form-counter"/>
                                                            </children>
                                                        </HBox>
                                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                            <children>
                                                                <Button fx:id="hfTextToImageButton" text="🎨 Générer image depuis texte" onAction="#onHfTextToImage" mnemonicParsing="false"
                                                                        styleClass="posts-form-browse-btn"/>
                                                            </children>
                                                        </HBox>
                                                        <TextArea fx:id="formContenuArea" promptText="Décrivez votre expérience de voyage (min 50 caractères)" wrapText="true" prefRowCount="8" minHeight="120.0" styleClass="posts-form-textarea"/>
                                                    </children>
                                                </VBox>

                                                <!-- Buttons -->
                                                <HBox spacing="12.0" alignment="CENTER_RIGHT">
                                                    <children>
                                                        <Button text="Annuler" onAction="#onCancelForm" styleClass="posts-clear-btn"/>
                                                        <Button text="Enregistrer" onAction="#onSaveForm" styleClass="posts-save-btn"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                            </content>
                                        </ScrollPane>

                                        <VBox fx:id="hfAiOverlay" alignment="CENTER" spacing="14.0" visible="false" managed="false"
                                              style="-fx-background-color: rgba(7,17,46,0.88); -fx-padding: 24;">
                                            <children>
                                                <Label fx:id="hfOverlayTitle" text="Génération en cours…" style="-fx-text-fill: #f8fafc; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <ProgressBar fx:id="hfProgressBar" prefWidth="320.0" progress="0.0"/>
                                                <ProgressIndicator fx:id="hfSpinner" prefWidth="40.0" prefHeight="40.0"/>
                                                <Label fx:id="hfOverlayDetail" wrapText="true" maxWidth="360.0"
                                                       style="-fx-text-fill: #cbd5e1; -fx-font-size: 12px;"/>
                                            </children>
                                        </VBox>
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>
                    </center>
                </BorderPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
