<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gestionoffres.OfferFormController"
            styleClass="signed-in-clean-shell immersive-root signed-in-shell-root">
    <left>
        <StackPane fx:id="signedInSidebarHost" maxHeight="Infinity" minHeight="0.0" maxWidth="328.0" minWidth="260.0" prefWidth="292.0"
                   styleClass="signed-in-home-sidebar-host signed-in-shell-sidebar-host"
                   style="-fx-background-color: linear-gradient(to bottom, #07112E 0%, #081430 48%, #0A1635 100%); -fx-padding: 0;">
            <children>
                <Region fx:id="signedInSidebarEdgeAura" maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" styleClass="smart-auth-edge-aura"/>
                <VBox fx:id="signedInSidebarShell" spacing="10.0" styleClass="sv-si-sidebar signed-in-sidebar-column sidebar-immersive smart-auth-sidebar smart-auth-sidebar-outer" style="-fx-background-color: transparent;">
                    <children>
                        <VBox spacing="10.0" styleClass="smart-auth-brand-dock">
                            <padding><Insets top="22.0" right="26.0" bottom="6.0" left="26.0"/></padding>
                            <children>
                                <VBox spacing="8.0" styleClass="smart-auth-brand-lockup">
                                    <children>
                                        <ImageView fitWidth="212.0" preserveRatio="true" styleClass="smart-auth-brand-logo">
                                            <image><Image url="@/assets/branding/smartvoyage-logo-tight.png"/></image>
                                        </ImageView>
                                        <Region fx:id="signedInBrandUnderlineBar" prefHeight="3.0" maxWidth="132.0" styleClass="smart-auth-accent-bar"/>
                                        <Label text="Desktop travel UI" styleClass="smart-auth-brand-strap"/>
                                    </children>
                                </VBox>
                                <Label fx:id="signedInSidebarSessionLabel" text="" styleClass="sv-si-session"/>
                            </children>
                        </VBox>
                        <Region prefHeight="1.0" maxWidth="Infinity" styleClass="smart-auth-rule smart-auth-rule-tight"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navHomeButton" text="Home" onAction="#onHome" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navOffersButton" text="Offers" onAction="#onOffres" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navAgenciesButton" text="Agencies" onAction="#onAgences" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navMessagesButton" text="Messages" onAction="#onMessagerie" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navRecommendationsButton" text="Recommendations" onAction="#onRecommandation" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navEventsButton" text="Events" onAction="#onEvenement" styleClass="sidebar-nav-item"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Separator styleClass="sidebar-rule"/>
                        <Button fx:id="navPremiumButton" text="Premium" onAction="#onPremium" styleClass="premium-nav-button" visible="false" managed="false"/>
                        <Button fx:id="navNotificationsButton" text="Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navProfileButton" text="My Profile" onAction="#onProfile" styleClass="sidebar-nav-item"/>
                        <Button fx:id="navDashboardButton" text="Dashboard IA" onAction="#onDashboardIa" styleClass="sidebar-nav-item"/>
                        <Separator styleClass="sidebar-rule"/>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sv-si-footer">
                            <children><Button fx:id="signedInLogoutIconButton" text="" onAction="#onLogout" styleClass="signed-in-footer-logout-button"/></children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </left>
    <center>
        <StackPane styleClass="signed-in-home-main-canvas signed-in-cosmic-canvas"
                   style="-fx-background-color: linear-gradient(to bottom, #2A174A 0%, #17052D 52%, #05010D 100%);">
            <children>
                <Pane fx:id="signedInCosmicStarfieldPane" styleClass="starfield-layer"/>
                <VBox spacing="14" style="-fx-background-color: transparent; -fx-padding: 24 28;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Button text="Back" onAction="#onBack" style="-fx-background-color: #4C1D95; -fx-text-fill: white; -fx-background-radius: 10;"/>
                                <Label fx:id="titleLabel" text="Créer une offre" style="-fx-text-fill: white; -fx-font-size: 30; -fx-font-weight: 700;"/>
                            </children>
                        </HBox>
                        <FlowPane fx:id="layoutFlowPane" hgap="18" vgap="18" prefWrapLength="1100" style="-fx-background-color: transparent;">
                            <children>
                                <VBox prefWidth="460" spacing="10" style="-fx-background-color: rgba(34, 26, 58, 0.85); -fx-border-color: #2E2550; -fx-background-radius: 16; -fx-border-radius: 16; -fx-padding: 12;">
                                    <children>
                                        <Label text="Aperçu de l'offre" style="-fx-text-fill: #A78BFA; -fx-font-size: 13;"/>
                                        <ImageView fx:id="previewImageView" fitWidth="436" fitHeight="230" preserveRatio="false"/>
                                        <Label fx:id="previewTitleLabel" style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: 700;"/>
                                        <FlowPane fx:id="previewCountriesPane" hgap="6" vgap="6"/>
                                        <Label fx:id="previewPriceLabel" style="-fx-text-fill: #F472B6; -fx-font-size: 24; -fx-font-weight: 700;"/>
                                        <Label fx:id="previewSeatsLabel" style="-fx-text-fill: #A78BFA;"/>
                                        <Label fx:id="previewDatesLabel" style="-fx-text-fill: #A78BFA;"/>
                                    </children>
                                </VBox>

                                <VBox prefWidth="620" spacing="8" style="-fx-background-color: rgba(34, 26, 58, 0.85); -fx-border-color: #2E2550; -fx-background-radius: 16; -fx-border-radius: 16; -fx-padding: 14;">
                                    <children>
                                        <Label text="Titre" style="-fx-text-fill: #A78BFA;"/>
                                        <TextField fx:id="titleField" promptText="Titre"/>
                                        <Label fx:id="titleErrorLabel" visible="false" managed="false" style="-fx-text-fill: #FCA5A5;"/>

                                        <Label text="Pays" style="-fx-text-fill: #A78BFA;"/>
                                        <VBox spacing="6" style="-fx-background-color: transparent;">
                                            <children>
                                                <FlowPane fx:id="countriesTagsPane" hgap="6" vgap="6" prefWrapLength="540"
                                                          style="-fx-background-color: #1C1535; -fx-border-color: #3B2F6B; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 14;">
                                                    <children>
                                                        <TextField fx:id="countriesSearchField" promptText="France, Italie, Espagne" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #A78BFA; -fx-font-size: 14;"/>
                                                    </children>
                                                </FlowPane>
                                            </children>
                                        </VBox>
                                        <Label fx:id="countriesErrorLabel" visible="false" managed="false" style="-fx-text-fill: #FCA5A5;"/>

                                        <Label text="Description" style="-fx-text-fill: #A78BFA;"/>
                                        <TextArea fx:id="descriptionArea" prefRowCount="3"/>

                                        <HBox spacing="10">
                                            <children>
                                                <VBox HBox.hgrow="ALWAYS" spacing="4">
                                                    <children>
                                                        <Label text="Date de départ" style="-fx-text-fill: #A78BFA;"/>
                                                        <DatePicker fx:id="departureDatePicker" maxWidth="Infinity"/>
                                                    </children>
                                                </VBox>
                                                <VBox HBox.hgrow="ALWAYS" spacing="4">
                                                    <children>
                                                        <Label text="Date de retour" style="-fx-text-fill: #A78BFA;"/>
                                                        <DatePicker fx:id="returnDatePicker" maxWidth="Infinity"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <Label fx:id="dateErrorLabel" visible="false" managed="false" style="-fx-text-fill: #FCA5A5;"/>

                                        <HBox spacing="10">
                                            <children>
                                                <VBox HBox.hgrow="ALWAYS" spacing="4">
                                                    <children>
                                                        <Label text="Prix" style="-fx-text-fill: #A78BFA;"/>
                                                        <TextField fx:id="priceField" promptText="Prix"/>
                                                    </children>
                                                </VBox>
                                                <VBox HBox.hgrow="ALWAYS" spacing="4">
                                                    <children>
                                                        <Label text="Devise" style="-fx-text-fill: #A78BFA;"/>
                                                        <ComboBox fx:id="currencyCombo" maxWidth="Infinity"/>
                                                    </children>
                                                </VBox>
                                                <VBox HBox.hgrow="ALWAYS" spacing="4">
                                                    <children>
                                                        <Label text="Places disponibles" style="-fx-text-fill: #A78BFA;"/>
                                                        <TextField fx:id="seatsField" promptText="Places"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <Label fx:id="numbersErrorLabel" visible="false" managed="false" style="-fx-text-fill: #FCA5A5;"/>

                                        <Label text="Photo de couverture" style="-fx-text-fill: #A78BFA;"/>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <children>
                                                <Button text="📁 Choose Photo" onAction="#onChooseImage"
                                                        style="-fx-background-color: #7C3AED; -fx-text-fill: white; -fx-background-radius: 10;"/>
                                                <Label fx:id="photoFileNameLabel" text="Aucune photo sélectionnée" style="-fx-text-fill: #C4B5FD;"/>
                                            </children>
                                        </HBox>

                                        <Label fx:id="statusLabel" style="-fx-text-fill: #A78BFA;"/>
                                        <Button text="Enregistrer l'offre" onAction="#onSave"
                                                style="-fx-background-color: linear-gradient(to right,#DB2777,#7C3AED); -fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: 700; -fx-background-radius: 12; -fx-max-width: Infinity;"/>
                                    </children>
                                </VBox>
                            </children>
                        </FlowPane>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
